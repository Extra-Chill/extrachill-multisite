{
  "auto_cleanup": false,
  "changelog_target": "docs/CHANGELOG.md",
  "extensions": {
    "wordpress": {}
  },
  "id": "extrachill-multisite",
  "remote_path": "wp-content/plugins/extrachill-multisite",
  "version_targets": [
    {
      "file": "extrachill-multisite.php",
      "pattern": "Version:\\s*([0-9.]+)"
    },
    {
      "file": "extrachill-multisite.php",
      "pattern": "EXTRACHILL_MULTISITE_VERSION',\\s*'([0-9.]+)'"
    }
  ]
}